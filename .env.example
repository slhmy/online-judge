# Configuration with environment variables
# Copy to .env for local development

# Database
DATABASE_URL=postgres://oj:oj@localhost:5432/oj?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# Auth (Identra)
IDENTRA_JWKS_URL=http://localhost:8081/.well-known/jwks.json

# Services
GRPC_PORT=8002
HTTP_PORT=8080

# Service Addresses (all point to center service)
PROBLEM_SERVICE_ADDR=localhost:8002
SUBMISSION_SERVICE_ADDR=localhost:8002
CONTEST_SERVICE_ADDR=localhost:8002
NOTIFICATION_SERVICE_ADDR=localhost:8002
USER_SERVICE_ADDR=localhost:8002
IDENTRA_GRPC_HOST=localhost:50051
IDENTRA_HTTP_HOST=localhost:8081

# Judge
JUDGEHOST_ID=judgehost-01
ORCHESTRATOR_URL=http://localhost:8080

# MinIO / S3
S3_ENDPOINT=localhost:9000
S3_BUCKET=online-judge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# OAuth (GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback